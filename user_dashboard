<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Z-Traces — User Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Syne:wght@400;700;800&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg:#050a0e; --surface:#0d1b24; --surface2:#0f2030;
      --border:#1a3a4a; --accent:#00d4ff; --accent2:#00ff9d;
      --warn:#ff6b35; --text:#cce8f0; --muted:#4a7a8a;
      --font-mono:'Share Tech Mono',monospace; --font-display:'Syne',sans-serif;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    body{background:var(--bg);color:var(--text);font-family:var(--font-mono);min-height:100vh;}

    /* Grid bg */
    body::before{
      content:'';position:fixed;inset:0;pointer-events:none;
      background-image:linear-gradient(rgba(0,212,255,0.03) 1px,transparent 1px),
        linear-gradient(90deg,rgba(0,212,255,0.03) 1px,transparent 1px);
      background-size:40px 40px;
    }

    /* Topbar */
    .topbar{
      position:sticky;top:0;z-index:100;
      background:rgba(5,10,14,.95);backdrop-filter:blur(12px);
      border-bottom:1px solid var(--border);
      display:flex;align-items:center;justify-content:space-between;
      padding:0 32px;height:56px;
    }
    .topbar-brand{font-family:var(--font-display);font-weight:800;font-size:1.1rem;
      background:linear-gradient(135deg,var(--accent),var(--accent2));
      -webkit-background-clip:text;-webkit-text-fill-color:transparent;}
    .topbar-info{display:flex;align-items:center;gap:20px;font-size:.75rem;color:var(--muted);}
    .badge{background:rgba(0,212,255,0.1);border:1px solid rgba(0,212,255,0.3);
      color:var(--accent);padding:3px 10px;font-size:.65rem;letter-spacing:.12em;text-transform:uppercase;}
    .btn-logout{background:none;border:1px solid var(--border);color:var(--muted);
      font-family:var(--font-mono);font-size:.7rem;padding:6px 14px;cursor:pointer;
      letter-spacing:.1em;transition:all .2s;}
    .btn-logout:hover{border-color:var(--warn);color:var(--warn);}

    .layout{display:grid;grid-template-columns:1fr 340px;gap:0;min-height:calc(100vh - 56px);}

    /* Main area */
    .main{padding:28px 32px;border-right:1px solid var(--border);}

    /* Section heading */
    .sec-head{display:flex;align-items:center;gap:10px;margin-bottom:20px;}
    .sec-head h2{font-family:var(--font-display);font-weight:700;font-size:1rem;letter-spacing:.08em;}
    .sec-head::after{content:'';flex:1;height:1px;background:var(--border);}
    .tag{font-size:.6rem;letter-spacing:.15em;text-transform:uppercase;
      background:rgba(0,212,255,0.1);border:1px solid rgba(0,212,255,0.25);
      color:var(--accent);padding:2px 8px;}

    /* Locate card */
    .locate-card{
      background:var(--surface);border:1px solid var(--border);
      padding:28px;position:relative;margin-bottom:24px;
    }
    .locate-card::before{content:'';position:absolute;top:-1px;left:-1px;
      width:14px;height:14px;border-top:2px solid var(--accent);border-left:2px solid var(--accent);}
    .locate-card::after{content:'';position:absolute;bottom:-1px;right:-1px;
      width:14px;height:14px;border-bottom:2px solid var(--accent2);border-right:2px solid var(--accent2);}

    /* Floor map visual */
    .floor-map{
      background:#070f15;border:1px solid var(--border);
      height:260px;margin-bottom:20px;position:relative;overflow:hidden;
      display:flex;align-items:center;justify-content:center;
    }
    .floor-map svg{width:100%;height:100%;}

    /* Ping dot */
    .ping-dot{
      position:absolute;width:16px;height:16px;
      background:var(--accent);border-radius:50%;
      transform:translate(-50%,-50%);
      box-shadow:0 0 0 0 rgba(0,212,255,0.6);
      animation:pingAnim 2s infinite;display:none;
      transition:left .8s ease, top .8s ease;
    }
    @keyframes pingAnim{
      0%{box-shadow:0 0 0 0 rgba(0,212,255,.6)}
      70%{box-shadow:0 0 0 18px rgba(0,212,255,0)}
      100%{box-shadow:0 0 0 0 rgba(0,212,255,0)}
    }

    .loc-info-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:20px;}
    .loc-chip{background:#070f15;border:1px solid var(--border);padding:14px 16px;}
    .loc-chip .lc-label{font-size:.62rem;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-bottom:6px;}
    .loc-chip .lc-val{font-family:var(--font-display);font-size:1.2rem;font-weight:700;color:var(--accent);}
    .loc-chip .lc-val.green{color:var(--accent2);}

    .btn-locate{
      background:transparent;border:1px solid var(--accent);
      color:var(--accent);font-family:var(--font-display);font-weight:700;
      font-size:.82rem;letter-spacing:.18em;text-transform:uppercase;
      padding:14px 28px;cursor:pointer;transition:all .25s;
      position:relative;overflow:hidden;
    }
    .btn-locate::before{content:'';position:absolute;inset:0;background:var(--accent);
      transform:translateX(-100%);transition:.25s;z-index:0;}
    .btn-locate:hover::before{transform:translateX(0);}
    .btn-locate:hover{color:var(--bg);}
    .btn-locate span{position:relative;z-index:1;}
    .btn-locate:disabled{opacity:.4;cursor:not-allowed;}
    .btn-locate.scanning span::after{content:' ...';animation:dots 1.2s infinite;}
    @keyframes dots{0%{content:' .'}33%{content:' ..'}66%{content:' ...'}100%{content:' .'}}

    /* Wi-Fi signals panel */
    .signal-list{display:flex;flex-direction:column;gap:8px;margin-top:16px;}
    .signal-row{
      display:flex;align-items:center;gap:12px;
      background:#070f15;border:1px solid var(--border);padding:10px 14px;
      font-size:.75rem;
    }
    .signal-ssid{flex:1;color:var(--text);}
    .signal-bssid{color:var(--muted);font-size:.68rem;flex:1;}
    .rssi-bar-wrap{width:80px;height:6px;background:#1a3a4a;border-radius:3px;overflow:hidden;}
    .rssi-bar{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--warn),var(--accent));transition:width .5s;}
    .rssi-val{color:var(--accent2);font-size:.72rem;min-width:42px;text-align:right;}

    /* Sidebar */
    .sidebar{padding:28px 24px;overflow-y:auto;max-height:calc(100vh - 56px);}
    .hist-item{
      background:var(--surface);border:1px solid var(--border);border-left:3px solid var(--accent);
      padding:14px 16px;margin-bottom:10px;cursor:pointer;transition:all .2s;
    }
    .hist-item:hover{border-color:var(--accent);background:rgba(0,212,255,0.04);}
    .hist-item .hi-time{font-size:.65rem;color:var(--muted);margin-bottom:4px;}
    .hist-item .hi-floor{font-family:var(--font-display);font-weight:700;font-size:.9rem;color:var(--accent);}
    .hist-item .hi-coord{font-size:.68rem;color:var(--muted);margin-top:2px;}
    .no-hist{font-size:.75rem;color:var(--muted);text-align:center;padding:40px 0;}
  </style>
</head>
<body>
<div class="topbar">
  <div class="topbar-brand">Z-TRACES</div>
  <div class="topbar-info">
    <span class="badge">USER</span>
    <span id="userName">Loading...</span>
    <button class="btn-logout" onclick="logout()">Logout</button>
  </div>
</div>

<div class="layout">
  <!-- Main -->
  <div class="main">
    <div class="sec-head">
      <h2>Locate Current Position</h2>
      <span class="tag">Real-time</span>
    </div>

    <div class="locate-card">
      <!-- Floor Map -->
      <div class="floor-map" id="floorMap">
        <svg viewBox="0 0 600 240" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
          <!-- Building outline -->
          <rect x="20" y="20" width="560" height="200" fill="none" stroke="#1a3a4a" stroke-width="1.5"/>
          <!-- Rooms -->
          <rect x="20" y="20" width="140" height="100" fill="none" stroke="#1a3a4a" stroke-width="1"/>
          <rect x="160" y="20" width="140" height="100" fill="none" stroke="#1a3a4a" stroke-width="1"/>
          <rect x="300" y="20" width="140" height="100" fill="none" stroke="#1a3a4a" stroke-width="1"/>
          <rect x="440" y="20" width="140" height="100" fill="none" stroke="#1a3a4a" stroke-width="1"/>
          <rect x="20" y="120" width="186" height="100" fill="none" stroke="#1a3a4a" stroke-width="1"/>
          <rect x="206" y="120" width="188" height="100" fill="none" stroke="#1a3a4a" stroke-width="1"/>
          <rect x="394" y="120" width="186" height="100" fill="none" stroke="#1a3a4a" stroke-width="1"/>
          <!-- Labels -->
          <text x="55" y="75" fill="#1a3a4a" font-size="9" font-family="monospace">LAB-101</text>
          <text x="196" y="75" fill="#1a3a4a" font-size="9" font-family="monospace">LAB-102</text>
          <text x="336" y="75" fill="#1a3a4a" font-size="9" font-family="monospace">CONF-A</text>
          <text x="476" y="75" fill="#1a3a4a" font-size="9" font-family="monospace">STAFF</text>
          <text x="70" y="175" fill="#1a3a4a" font-size="9" font-family="monospace">LIBRARY</text>
          <text x="255" y="175" fill="#1a3a4a" font-size="9" font-family="monospace">LOBBY</text>
          <text x="445" y="175" fill="#1a3a4a" font-size="9" font-family="monospace">CAFETERIA</text>
          <!-- AP markers -->
          <circle cx="160" cy="70" r="5" fill="none" stroke="#00d4ff" stroke-width="1" opacity=".5"/>
          <circle cx="160" cy="70" r="2" fill="#00d4ff" opacity=".5"/>
          <circle cx="440" cy="70" r="5" fill="none" stroke="#00d4ff" stroke-width="1" opacity=".5"/>
          <circle cx="440" cy="70" r="2" fill="#00d4ff" opacity=".5"/>
          <circle cx="300" cy="170" r="5" fill="none" stroke="#00d4ff" stroke-width="1" opacity=".5"/>
          <circle cx="300" cy="170" r="2" fill="#00d4ff" opacity=".5"/>
          <!-- Floor label -->
          <text x="550" y="235" fill="#1a3a4a" font-size="9" font-family="monospace" text-anchor="end" id="floorLabel">FLOOR: —</text>
        </svg>
        <div class="ping-dot" id="pingDot"></div>
      </div>

      <!-- Info chips -->
      <div class="loc-info-grid">
        <div class="loc-chip">
          <div class="lc-label">Floor</div>
          <div class="lc-val" id="chipFloor">—</div>
        </div>
        <div class="loc-chip">
          <div class="lc-label">X, Y Coords</div>
          <div class="lc-val" id="chipCoords">—</div>
        </div>
        <div class="loc-chip">
          <div class="lc-label">Area</div>
          <div class="lc-val green" id="chipArea">—</div>
        </div>
      </div>

      <button class="btn-locate" id="locBtn" onclick="localize()"><span>Scan &amp; Locate</span></button>

      <!-- Agent Status Bar -->
      <div style="margin-top:14px;display:flex;align-items:center;gap:10px;font-size:.68rem;">
        <span id="agentDot" style="display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--muted);transition:all .3s;flex-shrink:0;"></span>
        <span id="agentText" style="color:var(--muted);">Agent status checking...</span>
      </div>
    </div>

    <!-- Wi-Fi signals -->
    <div class="sec-head" style="margin-top:8px;">
      <h2>Detected Wi-Fi Signals</h2>
      <span id="signalSource" style="font-size:.65rem;color:var(--muted);padding:2px 8px;border:1px solid var(--border);margin-left:8px;"></span>
    </div>
    <div class="signal-list" id="signalList">
      <div style="color:var(--muted);font-size:.75rem;padding:16px;">Click "Scan & Locate" to detect signals.</div>
    </div>
  </div>

  <!-- Sidebar: History -->
  <div class="sidebar">
    <div class="sec-head">
      <h2>Location History</h2>
    </div>
    <div id="historyList">
      <div class="no-hist">No history yet.<br/>Perform a localization first.</div>
    </div>
  </div>
</div>

<script>
  // Auth check
  const user = JSON.parse(localStorage.getItem('zt_user') || '{}');
  document.getElementById('userName').textContent = user.name || 'User';

  function logout() {
    localStorage.clear();
    window.location.href = 'index.html';
  }

  const AGENT_URL = 'http://localhost:5001';
  const AREAS = ['LAB-101','LAB-102','CONF-A','STAFF','LIBRARY','LOBBY','CAFETERIA'];

  // Fallback mock signals (agent nahi chala ho tab)
  const MOCK_SIGNALS = [
    {ssid:'CampusNet-5G', bssid:'AA:BB:CC:11:22:33', rssi:-42},
    {ssid:'CampusNet-2G', bssid:'AA:BB:CC:44:55:66', rssi:-58},
    {ssid:'LibraryWiFi',  bssid:'DD:EE:FF:77:88:99', rssi:-71},
    {ssid:'Admin-Net',    bssid:'11:22:33:AA:BB:CC', rssi:-82},
  ];

  // ── Agent status check on page load ──
  let agentAvailable = false;
  async function checkAgent() {
    try {
      const res = await fetch(AGENT_URL + '/health', {signal: AbortSignal.timeout(1500)});
      const data = await res.json();
      if (data.status === 'ok') {
        agentAvailable = true;
        setAgentStatus(true, data.os);
      }
    } catch {
      agentAvailable = false;
      setAgentStatus(false);
    }
  }

  function setAgentStatus(online, os='') {
    const dot  = document.getElementById('agentDot');
    const text = document.getElementById('agentText');
    if (online) {
      dot.style.background  = 'var(--accent2)';
      dot.style.boxShadow   = '0 0 6px var(--accent2)';
      text.textContent = `Agent Online (${os}) — Real Wi-Fi scanning active`;
      text.style.color = 'var(--accent2)';
    } else {
      dot.style.background  = 'var(--warn)';
      dot.style.boxShadow   = '0 0 6px var(--warn)';
      text.textContent = 'Agent Offline — Using mock signals | Run: python wifi_agent.py';
      text.style.color = 'var(--warn)';
    }
  }

  checkAgent();

  // ── Real Wi-Fi scan from Agent ──
  async function getRealSignals() {
    const res = await fetch(AGENT_URL + '/scan', {signal: AbortSignal.timeout(8000)});
    const data = await res.json();
    if (!data.success || !data.signals.length) throw new Error('No signals');
    return data.signals;
  }

  let history = JSON.parse(localStorage.getItem('zt_hist') || '[]');
  renderHistory();

  async function localize() {
    const btn = document.getElementById('locBtn');
    btn.disabled = true; btn.classList.add('scanning');

    let signals = [];
    let sourceLabel = '';

    // Step 1: Real Wi-Fi signals from agent
    try {
      signals = await getRealSignals();
      sourceLabel = '🟢 Real Wi-Fi';
      agentAvailable = true;
      setAgentStatus(true);
    } catch {
      signals = MOCK_SIGNALS.map(s => ({...s, rssi: s.rssi + Math.floor(Math.random()*10 - 5)}));
      sourceLabel = '🟡 Mock Data';
      agentAvailable = false;
      setAgentStatus(false);
    }

    document.getElementById('signalSource').textContent = sourceLabel;
    renderSignals(signals);

    // Step 2: Send to backend — ALWAYS, even mock signals
    // Backend karega KNN localize + MongoDB mein save
    let result = null;
    try {
      const res = await fetch('/api/localize', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer ' + localStorage.getItem('zt_token')
        },
        body: JSON.stringify({ signals })
      });
      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.error || res.status);
      }
      result = await res.json();
      // Backend ne save kar liya — no need for separate POST
    } catch (backendErr) {
      console.warn('Backend error:', backendErr.message);
      // Backend nahi mila — local fallback result banao
      result = {
        floor: Math.floor(Math.random()*3)+1,
        x:     Math.floor(Math.random()*500+30),
        y:     Math.floor(Math.random()*180+30),
        area:  AREAS[Math.floor(Math.random()*AREAS.length)]
      };
      // Manually backend mein save karne ki koshish
      await saveToBackend(result);
    }

    showLocation(result);
    btn.disabled = false; btn.classList.remove('scanning');
  }

  // Backend mein location record save karo
  async function saveToBackend(data) {
    try {
      await fetch('/api/location-history', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer ' + localStorage.getItem('zt_token')
        },
        body: JSON.stringify({
          floor: data.floor,
          x:     data.x,
          y:     data.y,
          area:  data.area || ''
        })
      });
    } catch (e) {
      console.warn('Save to backend failed:', e.message);
    }
  }

  function showLocation(data) {
    document.getElementById('chipFloor').textContent = 'Floor ' + data.floor;
    document.getElementById('chipCoords').textContent = data.x + ', ' + data.y;
    document.getElementById('chipArea').textContent = data.area || '—';
    document.getElementById('floorLabel').textContent = 'FLOOR: ' + data.floor;

    // Move ping dot on SVG map (viewBox 600x240)
    const dot = document.getElementById('pingDot');
    dot.style.display = 'block';
    dot.style.left = ((data.x / 600) * 100) + '%';
    dot.style.top  = ((data.y / 240) * 100) + '%';

    // Save to localStorage for sidebar history display
    const entry = {
      time:  new Date().toLocaleString(),
      floor: data.floor,
      x:     data.x,
      y:     data.y,
      area:  data.area
    };
    history.unshift(entry);
    if (history.length > 50) history = history.slice(0, 50);
    localStorage.setItem('zt_hist', JSON.stringify(history));
    renderHistory();
  }

  function renderSignals(signals) {
    const el = document.getElementById('signalList');
    el.innerHTML = signals.map(s => {
      const pct = Math.min(100, Math.max(0, (s.rssi + 100) * 2));
      return `<div class="signal-row">
        <span class="signal-ssid">${s.ssid}</span>
        <span class="signal-bssid">${s.bssid}</span>
        <div class="rssi-bar-wrap"><div class="rssi-bar" style="width:${pct}%"></div></div>
        <span class="rssi-val">${s.rssi} dBm</span>
      </div>`;
    }).join('');
  }

  function renderHistory() {
    const el = document.getElementById('historyList');
    if (!history.length) {
      el.innerHTML = '<div class="no-hist">No history yet.<br/>Perform a localization first.</div>';
      return;
    }
    el.innerHTML = history.map(h => `
      <div class="hist-item">
        <div class="hi-time">${h.time}</div>
        <div class="hi-floor">Floor ${h.floor} &mdash; ${h.area||'Unknown'}</div>
        <div class="hi-coord">X:${h.x} Y:${h.y}</div>
      </div>`).join('');
  }
</script>
</body>
</html>
